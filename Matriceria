const MONTHLY = [{"mes":"2024-01","prom":0.18,"max":0.2,"n":5},{"mes":"2024-02","prom":0.3,"max":0.7,"n":14},{"mes":"2024-03","prom":0.457,"max":0.6,"n":7},{"mes":"2024-04","prom":0.071,"max":0.2,"n":7},{"mes":"2024-05","prom":0.2,"max":0.2,"n":1},{"mes":"2024-06","prom":0.4,"max":0.4,"n":2},{"mes":"2024-07","prom":0.167,"max":0.3,"n":6},{"mes":"2024-08","prom":0.312,"max":0.5,"n":8},{"mes":"2024-09","prom":0.3,"max":0.7,"n":6},{"mes":"2024-10","prom":0.34,"max":0.6,"n":5},{"mes":"2024-11","prom":0.12,"max":0.4,"n":10},{"mes":"2024-12","prom":0.6,"max":0.6,"n":2},{"mes":"2025-01","prom":0.375,"max":0.7,"n":8},{"mes":"2025-02","prom":0.4,"max":0.4,"n":4},{"mes":"2025-03","prom":0.275,"max":0.9,"n":4},{"mes":"2025-04","prom":0.11,"max":0.2,"n":10},{"mes":"2025-05","prom":0.2,"max":0.2,"n":1},{"mes":"2025-06","prom":0.25,"max":0.5,"n":2},{"mes":"2025-09","prom":0.143,"max":0.3,"n":7},{"mes":"2025-10","prom":0.922,"max":1.1,"n":9},{"mes":"2025-11","prom":0.5,"max":0.6,"n":4},{"mes":"2025-12","prom":0.22,"max":0.3,"n":5},{"mes":"2026-01","prom":0.16,"max":0.2,"n":10},{"mes":"2026-02","prom":0.3,"max":0.4,"n":10},{"mes":"2026-03","prom":0.05,"max":0.1,"n":6},{"mes":"2026-08","prom":0.1,"max":0.1,"n":1}];

// ─────────────────────────────────────────────────────
// CHART REGISTRY
// ─────────────────────────────────────────────────────
const charts = {};
function destroyChart(id) { if(charts[id]){ charts[id].destroy(); delete charts[id]; } }

// ─────────────────────────────────────────────────────
// RELOJ
// ─────────────────────────────────────────────────────
function updateClock(){
  const n = new Date();
  const p = v => String(v).padStart(2,'0');
  document.getElementById('clock').textContent = `${p(n.getDate())}/${p(n.getMonth()+1)}/${n.getFullYear()} ${p(n.getHours())}:${p(n.getMinutes())}`;
}
updateClock(); setInterval(updateClock, 60000);

// ─────────────────────────────────────────────────────
// TABS
// ─────────────────────────────────────────────────────
function switchTab(id, btn){
  document.querySelectorAll('.nav-tab').forEach(t => t.classList.remove('active'));
  document.querySelectorAll('.section').forEach(s => { s.classList.remove('active'); s.classList.remove('fade-in'); });
  btn.classList.add('active');
  const sec = document.getElementById('sec-'+id);
  sec.classList.add('active');
  void sec.offsetWidth;
  sec.classList.add('fade-in');
  if(id === 'estano') buildEstano('todos');
  if(id === 'moldes') buildMoldes('todos');
}

// ─────────────────────────────────────────────────────
// HELPERS
// ─────────────────────────────────────────────────────
function difColor(d){
  if(d >= 0.8) return '#e05252';
  if(d >= 0.5) return '#e8a020';
  if(d >= 0.3) return '#e8b84b';
  return '#4caf7d';
}
function difBadge(d){
  if(d >= 0.8) return '<span class="badge badge-red">CRÍTICO</span>';
  if(d >= 0.5) return '<span class="badge badge-amber">ALTO</span>';
  if(d >= 0.3) return '<span class="badge badge-gray">MODERADO</span>';
  return '<span class="badge badge-green">OK</span>';
}
function fmtFecha(f){ return f.split('-').reverse().join('/'); }

// ─────────────────────────────────────────────────────
// FILTRO AÑO (ESTAÑO)
// ─────────────────────────────────────────────────────
let currentYear = 'todos';

function filterYear(y, btn){
  currentYear = y;
  document.querySelectorAll('#year-filters .filter-btn').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
  buildEstano(y);
}

function getEstanoData(y){
  if(y === 'todos') return ESTANO;
  return ESTANO.filter(r => r.f.startsWith(y));
}

// ─────────────────────────────────────────────────────
// BUILD ESTAÑO
// ─────────────────────────────────────────────────────
function buildEstano(y){
  const data = getEstanoData(y);
  const monthly = y === 'todos' ? MONTHLY : MONTHLY.filter(m => m.mes.startsWith(y));

  // KPIs
  const last = data[data.length-1];
  const avgDif = data.reduce((s,r)=>s+r.d,0)/data.length;
  const maxDif = Math.max(...data.map(r=>r.d));
  const rectifs = data.filter(r => r.o && r.o.toLowerCase().includes('rectif')).length;
  const ajustes = data.filter(r => r.v !== null).length;

  document.getElementById('kpis-estano').innerHTML = `
    <div class="kpi">
      <div class="kpi-accent" style="background:var(--accent)"></div>
      <div class="kpi-label">Última medición</div>
      <div class="kpi-value" style="font-size:18px;color:var(--text)">${fmtFecha(last.f)}</div>
      <div class="kpi-meta">Centro: ${last.c.toFixed(2)} mm · Esquina: ${last.e.toFixed(2)} mm</div>
      ${difBadge(last.d)}
    </div>
    <div class="kpi">
      <div class="kpi-accent" style="background:${difColor(last.d)}"></div>
      <div class="kpi-label">Diferencia actual</div>
      <div class="kpi-value" style="color:${difColor(last.d)}">${last.d.toFixed(2)}</div>
      <div class="kpi-meta">mm · Centro − Esquina</div>
    </div>
    <div class="kpi">
      <div class="kpi-accent" style="background:var(--blue)"></div>
      <div class="kpi-label">Diferencia promedio</div>
      <div class="kpi-value" style="color:var(--blue)">${avgDif.toFixed(3)}</div>
      <div class="kpi-meta">mm · ${data.length} registros</div>
    </div>
    <div class="kpi">
      <div class="kpi-accent" style="background:var(--amber)"></div>
      <div class="kpi-label">Intervenciones</div>
      <div class="kpi-value" style="color:var(--amber)">${ajustes}</div>
      <div class="kpi-meta">ajustes · ${rectifs} rectificaciones</div>
    </div>
  `;

  // CHART LÍNEA
  destroyChart('linea');
  charts['linea'] = new Chart(document.getElementById('chartLinea'), {
    type: 'line',
    data: {
      labels: data.map(r => fmtFecha(r.f)),
      datasets: [
        { label:'Centro', data: data.map(r=>r.c), borderColor:'#5b9cf6', backgroundColor:'rgba(91,156,246,0.05)', tension:0.3, pointRadius:2, pointHoverRadius:5, borderWidth:2 },
        { label:'Esquina', data: data.map(r=>r.e), borderColor:'#4caf7d', backgroundColor:'rgba(76,175,125,0.05)', tension:0.3, pointRadius:2, pointHoverRadius:5, borderWidth:2 },
        { label:'Diferencia', data: data.map(r=>r.d), borderColor:'#e05252', backgroundColor:'rgba(224,82,82,0.04)', tension:0.3, pointRadius:2, pointHoverRadius:5, borderWidth:1.5, borderDash:[5,3] }
      ]
    },
    options: {
      responsive:true, maintainAspectRatio:false,
      interaction:{ mode:'index', intersect:false },
      plugins: {
        legend:{display:false},
        tooltip:{ callbacks:{ label: ctx=>`${ctx.dataset.label}: ${ctx.parsed.y.toFixed(2)} mm` } }
      },
      scales:{
        x:{ ticks:{maxRotation:45,autoSkip:true,maxTicksLimit:24,font:{size:10},color:'#555a68'}, grid:{color:'rgba(255,255,255,0.04)'} },
        y:{ title:{display:true,text:'mm',color:'#555a68',font:{size:11}}, ticks:{color:'#555a68',font:{size:11}}, grid:{color:'rgba(255,255,255,0.04)'} }
      }
    }
  });

  // CHART MENSUAL
  destroyChart('mensual');
  charts['mensual'] = new Chart(document.getElementById('chartMensual'), {
    type: 'bar',
    data: {
      labels: monthly.map(m => {
        const [y,mo] = m.mes.split('-');
        const meses = ['','Ene','Feb','Mar','Abr','May','Jun','Jul','Ago','Sep','Oct','Nov','Dic'];
        return meses[+mo]+' '+y.slice(2);
      }),
      datasets: [
        { label:'Promedio', data: monthly.map(m=>m.prom), backgroundColor: monthly.map(m => m.prom >= 0.8 ? '#e05252' : m.prom >= 0.5 ? '#e8a020' : m.prom >= 0.3 ? '#e8b84b' : '#4caf7d'), borderRadius:3, borderWidth:0 },
        { label:'Máximo', data: monthly.map(m=>m.max), type:'line', borderColor:'rgba(224,82,82,0.5)', borderWidth:1.5, borderDash:[4,3], pointRadius:2, tension:0.3, backgroundColor:'transparent' }
      ]
    },
    options:{
      responsive:true, maintainAspectRatio:false,
      plugins:{ legend:{display:false}, tooltip:{ callbacks:{ label: ctx=>`${ctx.dataset.label}: ${ctx.parsed.y.toFixed(3)} mm` } } },
      scales:{
        x:{ ticks:{maxRotation:45,autoSkip:true,maxTicksLimit:12,font:{size:9},color:'#555a68'}, grid:{display:false} },
        y:{ ticks:{color:'#555a68',font:{size:10}}, grid:{color:'rgba(255,255,255,0.04)'} }
      }
    }
  });

  // CHART DISTRIBUCIÓN
  const buckets = {'0.0':0,'0.1–0.2':0,'0.3–0.4':0,'0.5–0.6':0,'0.7–0.9':0,'≥ 1.0':0};
  data.forEach(r=>{
    if(r.d===0) buckets['0.0']++;
    else if(r.d<=0.2) buckets['0.1–0.2']++;
    else if(r.d<=0.4) buckets['0.3–0.4']++;
    else if(r.d<=0.6) buckets['0.5–0.6']++;
    else if(r.d<=0.9) buckets['0.7–0.9']++;
    else buckets['≥ 1.0']++;
  });
  destroyChart('dist');
  charts['dist'] = new Chart(document.getElementById('chartDist'), {
    type:'bar',
    data:{
      labels: Object.keys(buckets),
      datasets:[{ label:'Registros', data:Object.values(buckets), backgroundColor:['#4caf7d','#5b9cf6','#e8b84b','#e8a020','#e05252','#791919'], borderRadius:4, borderWidth:0 }]
    },
    options:{
      responsive:true, maintainAspectRatio:false,
      plugins:{ legend:{display:false} },
      scales:{
        x:{ ticks:{color:'#555a68',font:{size:10}}, grid:{display:false} },
        y:{ ticks:{stepSize:5,color:'#555a68',font:{size:10}}, grid:{color:'rgba(255,255,255,0.04)'} }
      }
    }
  });

  // CHART VUELTAS
  const ajData = data.filter(r => r.v !== null);
  destroyChart('vueltas');
  charts['vueltas'] = new Chart(document.getElementById('chartVueltas'), {
    type:'bar',
    data:{
      labels: ajData.map(r => fmtFecha(r.f)),
      datasets:[{ label:'Vueltas', data:ajData.map(r=>r.v), backgroundColor:'rgba(232,184,75,0.6)', borderColor:'#e8b84b', borderWidth:1, borderRadius:3 }]
    },
    options:{
      responsive:true, maintainAspectRatio:false,
      plugins:{ legend:{display:false}, tooltip:{ callbacks:{ label: ctx=>`${ctx.parsed.y} vueltas` } } },
      scales:{
        x:{ ticks:{maxRotation:45,autoSkip:true,maxTicksLimit:20,font:{size:9},color:'#555a68'}, grid:{display:false} },
        y:{ title:{display:true,text:'Vueltas',color:'#555a68',font:{size:10}}, ticks:{color:'#555a68',font:{size:10}}, grid:{color:'rgba(255,255,255,0.04)'} }
      }
    }
  });

  // TABLA
  const conObs = [...data].filter(r=>r.o).reverse().slice(0,20);
  document.getElementById('tabla-estano').innerHTML = conObs.map(r=>`
    <tr>
      <td class="td-date">${fmtFecha(r.f)}</td>
      <td class="td-num">${r.c.toFixed(2)}</td>
      <td class="td-num">${r.e.toFixed(2)}</td>
      <td class="td-num" style="color:${difColor(r.d)};font-weight:500">${r.d.toFixed(2)}</td>
      <td class="td-num">${r.v !== null ? r.v : '—'}</td>
      <td class="td-num">${r.mm !== null ? r.mm.toFixed(2) : '—'}</td>
      <td class="td-obs">${r.o || '—'}</td>
    </tr>
  `).join('');
}

// ─────────────────────────────────────────────────────
// FILTRO MOLDES
// ─────────────────────────────────────────────────────
function filterMoldes(f, btn){
  document.querySelectorAll('#molde-filters .filter-btn').forEach(b=>b.classList.remove('active'));
  btn.classList.add('active');
  buildMoldes(f);
}

function buildMoldes(filtro){
  const data = filtro === 'todos' ? MOLDES : MOLDES.filter(m=>m.estado===filtro);

  // KPIs
  const total = MOLDES.length;
  const ops = MOLDES.filter(m=>m.estado==='Operativo').length;
  const crom = MOLDES.filter(m=>m.cromado==='Sí').length;
  const exc = MOLDES.filter(m=>m.enPeso==='Excedido').length;

  document.getElementById('kpis-moldes').innerHTML = `
    <div class="kpi">
      <div class="kpi-accent" style="background:var(--accent)"></div>
      <div class="kpi-label">Total moldes</div>
      <div class="kpi-value" style="color:var(--text)">${total}</div>
      <div class="kpi-meta">en seguimiento activo</div>
    </div>
    <div class="kpi">
      <div class="kpi-accent" style="background:var(--green)"></div>
      <div class="kpi-label">Operativos</div>
      <div class="kpi-value" style="color:var(--green)">${ops}</div>
      <div class="kpi-meta">${Math.round(ops/total*100)}% del total</div>
    </div>
    <div class="kpi">
      <div class="kpi-accent" style="background:var(--blue)"></div>
      <div class="kpi-label">Con cromado activo</div>
      <div class="kpi-value" style="color:var(--blue)">${crom}</div>
      <div class="kpi-meta">de ${total} moldes</div>
    </div>
    <div class="kpi">
      <div class="kpi-accent" style="background:var(--amber)"></div>
      <div class="kpi-label">Excedidos en peso</div>
      <div class="kpi-value" style="color:var(--amber)">${exc}</div>
      <div class="kpi-meta">sobre peso nominal</div>
    </div>
  `;

  // Alertas
  const enFab = MOLDES.filter(m=>m.estado==='En fabricación');
  const pendCrom = MOLDES.filter(m=>m.estado==='Operativo' && m.cromado==='No');
  let alertHTML = '';
  enFab.forEach(m => {
    alertHTML += `<div class="alert alert-red"><div class="alert-icon">⚠</div><div class="alert-text"><strong>${m.molde} #${m.num} — En fabricación:</strong> ${m.obs}</div></div>`;
  });
  if(pendCrom.length > 0){
    alertHTML += `<div class="alert alert-amber"><div class="alert-icon">◆</div><div class="alert-text"><strong>Cromado pendiente:</strong> ${pendCrom.map(m=>m.molde+' #'+m.num).join(', ')} — Revisar programación de cromado.</div></div>`;
  }
  document.getElementById('alertas-moldes').innerHTML = alertHTML;

  // CHART PESOS
  const withData = MOLDES.filter(m=>m.prom !== null);
  const withoutData = MOLDES.filter(m=>m.prom === null);
  destroyChart('pesos');
  charts['pesos'] = new Chart(document.getElementById('chartPesos'), {
    type:'bar',
    data:{
      labels: MOLDES.map(m=>`${m.molde} #${m.num}`),
      datasets:[
        { label:'Peso promedio real', data: MOLDES.map(m=>m.prom || 0),
          backgroundColor: MOLDES.map(m=>
            m.prom === null ? 'rgba(85,90,104,0.3)' :
            m.enPeso==='Óptimo' ? 'rgba(76,175,125,0.75)' : 'rgba(232,160,32,0.75)'
          ),
          borderColor: MOLDES.map(m=>
            m.prom === null ? '#555a68' :
            m.enPeso==='Óptimo' ? '#4caf7d' : '#e8a020'
          ),
          borderWidth:1, borderRadius:4
        },
        { label:'Peso nominal', data: MOLDES.map(m=>m.nominal),
          backgroundColor:'rgba(232,184,75,0.12)', borderColor:'rgba(232,184,75,0.4)', borderWidth:1.5, borderRadius:4, type:'bar'
        }
      ]
    },
    options:{
      indexAxis:'y', responsive:true, maintainAspectRatio:false,
      plugins:{ legend:{display:false}, tooltip:{ callbacks:{ label: ctx=>`${ctx.dataset.label}: ${ctx.parsed.x.toFixed(3)} kg` } } },
      scales:{
        x:{ title:{display:true,text:'kg',color:'#555a68',font:{size:11}}, ticks:{color:'#555a68',font:{size:10}}, grid:{color:'rgba(255,255,255,0.04)'} },
        y:{ ticks:{color:'#8b90a0',font:{size:11}}, grid:{display:false} }
      }
    }
  });

  // CHART ESTADOS
  const estadoCount = {'Operativo':0,'En calibración':0,'En fabricación':0};
  MOLDES.forEach(m=>estadoCount[m.estado]++);
  destroyChart('estados');
  charts['estados'] = new Chart(document.getElementById('chartEstados'), {
    type:'doughnut',
    data:{
      labels:['Operativo','En calibración','En fabricación'],
      datasets:[{ data:Object.values(estadoCount), backgroundColor:['#4caf7d','#5b9cf6','#e05252'], borderColor:'#14161a', borderWidth:3, hoverOffset:6 }]
    },
    options:{
      responsive:true, maintainAspectRatio:false,
      plugins:{ legend:{position:'bottom', labels:{color:'#8b90a0',font:{size:11},padding:14,boxWidth:12}} }
    }
  });

  // CHART CROMADO
  const cromCount = {'Sí':0,'En proceso':0,'No':0};
  MOLDES.forEach(m=>cromCount[m.cromado]++);
  destroyChart('cromado');
  charts['cromado'] = new Chart(document.getElementById('chartCromado'), {
    type:'doughnut',
    data:{
      labels:['Cromado activo','En proceso','Sin cromado'],
      datasets:[{ data:Object.values(cromCount), backgroundColor:['#4caf7d','#e8b84b','#555a68'], borderColor:'#14161a', borderWidth:3, hoverOffset:6 }]
    },
    options:{
      responsive:true, maintainAspectRatio:false,
      plugins:{ legend:{position:'bottom', labels:{color:'#8b90a0',font:{size:11},padding:14,boxWidth:12}} }
    }
  });

  // MOLDE CARDS
  function estadoBadge(e){
    if(e==='Operativo') return '<span class="badge badge-green">Operativo</span>';
    if(e==='En calibración') return '<span class="badge badge-blue">En calibración</span>';
    return '<span class="badge badge-red">En fabricación</span>';
  }
  function pesoBadge(p){ return p==='Óptimo' ? '<span class="badge badge-green">Óptimo</span>' : '<span class="badge badge-amber">Excedido</span>'; }
  function cromBadge(c){
    if(c==='Sí') return '<span class="badge badge-teal">Cromado</span>';
    if(c==='En proceso') return '<span class="badge badge-amber">En proceso</span>';
    return '<span class="badge badge-gray">Sin cromado</span>';
  }

  document.getElementById('molde-cards').innerHTML = data.map(m=>{
    const barPct = m.prom ? Math.min((m.prom/m.nominal)*100,130) : 0;
    const barColor = m.enPeso==='Óptimo' ? '#4caf7d' : '#e8a020';
    const nomPct = Math.min((m.nominal/m.nominal)*100,130);

    const viasHTML = m.vias.length > 0 ? `
      <div style="margin:10px 0 8px;">
        <div style="font-family:var(--font-mono);font-size:10px;color:var(--text3);letter-spacing:.06em;margin-bottom:5px;">PESOS POR VÍA (kg)</div>
        <div style="display:flex;flex-wrap:wrap;gap:4px;">
          ${m.vias.map((v,i)=>`<span style="background:var(--bg4);border-radius:3px;padding:2px 6px;font-family:var(--font-mono);font-size:10px;color:var(--text2);">V${i+1}: ${v.toFixed(3)}</span>`).join('')}
        </div>
      </div>` : '';

    return `
    <div class="molde-card">
      <div class="molde-card-head">
        <div>
          <div class="molde-name">${m.molde}</div>
          <div class="molde-num">N° ${m.num}</div>
        </div>
        <div style="text-align:right;">${estadoBadge(m.estado)}</div>
      </div>
      <div class="molde-row"><span class="molde-row-label">En peso</span>${pesoBadge(m.enPeso)}</div>
      <div class="molde-row"><span class="molde-row-label">Nominal</span><span class="molde-row-val">${m.nominal.toFixed(1)} kg</span></div>
      <div class="molde-row"><span class="molde-row-label">Promedio</span><span class="molde-row-val" style="color:${m.prom?barColor:'var(--text3)'}">${m.prom ? m.prom.toFixed(3)+' kg' : '— sin datos'}</span></div>
      ${m.prom ? `
      <div class="weight-bar">
        <div class="weight-bar-label"><span>0</span><span>Nom. ${m.nominal.toFixed(1)}</span><span>${(m.nominal*1.2).toFixed(1)}</span></div>
        <div class="weight-bar-track">
          <div class="weight-bar-fill" style="width:${Math.min(barPct/1.3,100).toFixed(1)}%;background:${barColor};"></div>
        </div>
      </div>` : ''}
      ${viasHTML}
      <div class="molde-row" style="margin-top:6px;"><span class="molde-row-label">Cromado</span>${cromBadge(m.cromado)}</div>
      <div class="molde-obs">${m.obs}</div>
      <div class="molde-date">Actualizado: ${m.fecha}</div>
    </div>`;
  }).join('');
}

// ─────────────────────────────────────────────────────
// INIT
// ─────────────────────────────────────────────────────
buildEstano('todos');
</script>
